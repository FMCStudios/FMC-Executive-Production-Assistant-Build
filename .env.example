# ── EPA env vars ───────────────────────────────────────────────
# Copy to .env.local and fill in. All of these must also exist in
# the Vercel project settings for production.

# Anthropic (brief generation)
ANTHROPIC_API_KEY=

# Google service account — shared by Sheets AND Drive.
# Share the target spreadsheet AND the Drive parent folder with the
# client_email below as Editor. The JWT scopes include both APIs.
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Drive — parent folder ID. EPA creates one sub-folder per client under this.
# Layout: <parent>/<Client Company>/FMC-Studios_<Type>_<Company>_<date>_v<N>.{pdf,json}
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# OAuth delegation for Drive uploads (personal Drive support).
# Service accounts can't own files in personal Drive — OAuth delegation solves.
# One-time setup: generate refresh token via OAuth Playground
# (https://developers.google.com/oauthplayground) with the Drive API scope
# https://www.googleapis.com/auth/drive.file under your own Google account.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# NextAuth v5 — Google SSO
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=https://fmc-epa.vercel.app

# Resend — profile-change notification email
RESEND_API_KEY=
ADMIN_EMAIL=

# Optional base-URL override (fallback when VERCEL_URL is unavailable)
NEXT_PUBLIC_BASE_URL=
